# ── Figma ─────────────────────────────────────────────────────────────────────
# Generate at: figma.com/settings → Personal access tokens
FIGMA_PAT=REPLACE_ME

# Comma-separated team IDs — from Figma URLs: figma.com/files/team/TEAM_ID/...
# Add your most active teams. More teams = longer crawl time.
FIGMA_TEAM_IDS=REPLACE_ME

# ── Asana ─────────────────────────────────────────────────────────────────────
# Generate at: app.asana.com/0/my-apps → Personal access tokens
ASANA_PAT=REPLACE_ME

# Your workspace GID — visit app.asana.com/api/1.0/workspaces while logged in
ASANA_WORKSPACE_GID=REPLACE_ME

# ── Vercel KV (hourly cache) ──────────────────────────────────────────────────
# Added automatically when you attach a KV store in the Vercel dashboard
KV_REST_API_URL=REPLACE_ME
KV_REST_API_TOKEN=REPLACE_ME

# ── App ───────────────────────────────────────────────────────────────────────
# Placeholder — update after first Vercel deploy confirms the URL
NEXT_PUBLIC_APP_URL=https://PLACEHOLDER.vercel.app

# Simple token to protect the /api routes from public access
# Generate with: openssl rand -hex 32
API_SECRET=REPLACE_WITH_RANDOM_SECRET
